{
  "name": "little-legend-studios",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm --workspace @little/shared run build",
    "dev:boot": "bash ./scripts/dev-up.sh",
    "docs:check": "node ./scripts/check-docs-sync.mjs",
    "smoke": "node ./scripts/smoke.mjs",
    "dev": "concurrently -n SHARED,API,WORKER,WEB -c cyan,blue,magenta,green \"npm:dev:shared\" \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:shared": "npm --workspace @little/shared run dev",
    "dev:api": "npm --workspace @little/api run dev",
    "dev:worker": "npm --workspace @little/worker run dev",
    "dev:web": "PORT=${WEB_PORT:-3000} npm --workspace @little/web run dev",
    "build": "npm --workspace @little/shared run build && npm --workspace @little/api run build && npm --workspace @little/worker run build && npm --workspace @little/web run build",
    "build:api": "npm --workspace @little/shared run build && npm --workspace @little/api run build",
    "build:worker": "npm --workspace @little/shared run build && npm --workspace @little/worker run build",
    "migrate:api": "npm --workspace @little/api run migrate",
    "start:api": "npm --workspace @little/api run start",
    "start:worker": "npm --workspace @little/worker run start",
    "typecheck": "npm --workspace @little/shared run build && npm --workspace @little/shared run typecheck && npm --workspace @little/api run typecheck && npm --workspace @little/worker run typecheck && npm --workspace @little/web run typecheck",
    "verify": "bash ./scripts/verify.sh",
    "smoke:local": "bash ./scripts/smoke-local.sh",
    "test:agents": "node --test scripts/agents/tests/*.test.mjs",
    "agents:dispatch": "bash ./scripts/agents/run.sh --mode=dispatch --profile=reliability --max-parallel=2 --batch-size=1 --automerge=true",
    "agents:dispatch:batch": "bash ./scripts/agents/run.sh --mode=dispatch --profile=reliability --max-parallel=2 --batch-size=2 --automerge=true",
    "agents:dry-run": "bash ./scripts/agents/run.sh --mode=dry-run --section=\"Architecture And Scale Hardening Backlog (2026-03-14)\" --batch-size=2 --write-runbook=true",
    "agents:resume": "bash ./scripts/agents/run.sh --mode=resume --profile=reliability --max-parallel=2 --automerge=true",
    "changed-files": "bash ./scripts/changed-files.sh",
    "deploy:summary": "bash ./scripts/deploy-summary.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.8.2"
  }
}
