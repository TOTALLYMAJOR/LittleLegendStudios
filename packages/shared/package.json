{
  "name": "@little/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./child-director": {
      "types": "./dist/child-director.d.ts",
      "default": "./dist/child-director.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json -w",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/child-director.test.js"
  }
}
